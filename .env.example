# Copy this file to `.env` and fill in your values.
# `.env` is gitignored and never committed. The backend reads it via load_dotenv().

# --- Required ---------------------------------------------------------------
# PostgreSQL connection string (Neon or local). Used by backend/database/db.py.
# No default — the backend raises on startup if this is missing.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# --- Optional (sensible defaults provided) ---------------------------------
# Comma-separated list of allowed CORS origins for the frontend.
# Defaults to the local dev frontend if unset.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend (set in the environment when building/running the frontend) ---
# Base URL of the backend API. The frontend defaults to http://127.0.0.1:8000
# if this is not set. Prefix NEXT_PUBLIC_ so Next.js exposes it to the client.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
